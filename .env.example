# ── evaltool configuration ───────────────────────────────────────────────────
# Copy this file to ".env" and adjust. All values are optional for local dev.

# Port the server listens on.
PORT=3000

# Optional anti-abuse key for the public instance. If set, creating a poll
# requires this key (entered once in the host dashboard, stored in localStorage).
# Leave empty for open local development.
HOST_KEY=

# ── LLM (OpenAI-compatible, e.g. vLLM) ───────────────────────────────────────
# If LLM_BASE_URL or LLM_MODEL is missing, the app degrades gracefully and shows
# "LLM not available at present" in place of any generated text — it never breaks.
#
# LLM_BASE_URL is the OpenAI-compatible root; the app POSTs to
# "${LLM_BASE_URL}/chat/completions". Include the version segment, e.g.:
#   https://my-vllm.example.org/v1
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# Optional generation tuning.
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=800
# Timeout for a single LLM request, in milliseconds.
LLM_TIMEOUT_MS=60000

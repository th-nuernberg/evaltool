# ── evaltool configuration ───────────────────────────────────────────────────
# Copy this file to ".env" and adjust. All values are optional for local dev.

# Port the server listens on.
PORT=3000

# URL prefix for hosting behind a reverse proxy, e.g. https://host/evaltool.
# Defaults to "evaltool". Set to empty (BASE_PATH=) to serve from the root.
# The reverse proxy must forward this prefix to the app (do not strip it).
BASE_PATH=evaltool

# Optional anti-abuse key for the public instance. If set, creating a poll
# requires this key (entered once in the host dashboard, stored in localStorage).
# Leave empty for open local development.
HOST_KEY=

# ── LLM (OpenAI-compatible) ──────────────────────────────────────────────────
# If LLM_BASE_URL or LLM_MODEL is missing, the app degrades gracefully and shows
# "LLM not available at present" in place of any generated text — it never breaks.
#
# LLM_BASE_URL is the OpenAI-compatible root; the app POSTs to
# "${LLM_BASE_URL}/chat/completions". Include the version segment.
LLM_BASE_URL=https://kiz1.in.ohmportal.de/llmproxy/v1

# Model id served by the proxy. AI features need this; the default below is the
# proxy's medium model — change it to use another.
LLM_MODEL=mistralai/Mistral-Medium-3.5-128B

# API token for the endpoint. A `.llmcredentials` file at the project root is
# auto-detected for local runs, so you can usually leave both of these empty.
# To override, provide ONE of:
#   LLM_API_KEY       the token inline, or
#   LLM_API_KEY_FILE  path to a file containing the token (Docker sets this to
#                     the bind-mounted ./.llmcredentials automatically).
LLM_API_KEY=
LLM_API_KEY_FILE=

# Optional generation tuning.
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=800
# Timeout for a single LLM request, in milliseconds.
LLM_TIMEOUT_MS=60000
